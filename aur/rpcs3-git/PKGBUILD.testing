# Maintainer: Zion Nimchuk <zionnimchuk@gmail.com>
# Submitter: Maxime Gauduin <alucryd@archlinux.org>

pkgname=rpcs3-git
pkgver=0.0.27.r43.g4d4a70ad0e
pkgrel=1
pkgdesc='A Sony PlayStation 3 emulator'
arch=(x86_64)
url=https://github.com/RPCS3/rpcs3
license=(GPL2)
depends=(
  alsa-lib
  glew
  glu
  libavcodec.so
  libavutil.so
  libevdev
  libgl
  libice
  libncursesw.so
  libpng
  libsm
  libswscale.so
  libx11
  libxext
  openal
  qt5-base
  qt5-declarative
  qt5-multimedia
  qt5-svg
  sdl2
  vulkan-icd-loader
  zlib
  curl
  pugixml
# newer system flatbuffers is incompatible with the version RPCS3 depends on
# flatbuffers
)
makedepends=(
  cmake
  git
  libglvnd
  libpulse
  python
  vulkan-validation-layers
)
optdepends=(
  libpulse
)
provides=(rpcs3)
conflicts=(rpcs3)
options=(!emptydirs !lto)
source=(
  git+https://github.com/RPCS3/rpcs3.git
)
sha256sums=(
  SKIP
)

pkgver() {
  cd rpcs3
  git describe --long --tags | sed 's/\([^-]*-g\)/r\1/;s/-/./g;s/^v//'
}

prepare() {
  cd rpcs3
  git remote set-url origin https://github.com/RPCS3/rpcs3.git
  _submodules=(
    3rdparty/hidapi/hidapi
    3rdparty/glslang/glslang
    3rdparty/SPIRV/SPIRV-Tools
    3rdparty/SPIRV/SPIRV-Headers
    3rdparty/yaml-cpp/yaml-cpp
#    3rdparty/xxHash
    3rdparty/cubeb/cubeb
    3rdparty/asmjit/asmjit
#    3rdparty/FAudio
    3rdparty/wolfssl/wolfssl
#    3rdparty/libpng/libpng
#    3rdparty/curl/curl
#    3rdparty/pugixml
    3rdparty/flatbuffers
    3rdparty/miniupnp/miniupnp
    3rdparty/SoundTouch/soundtouch
#    3rdparty/libusb/libusb
#    3rdparty/zlib/zlib
#    3rdparty/ffmpeg
    3rdparty/llvm/llvm
  )
  for path in ${_submodules[@]}; do
    git -c protocol.file.allow=always submodule update --init --filter=tree:0 "$path"
  done
}

build() {
  # GLIBCXX_ASSERTIONS is know to cause unwanted assertions and crash rpcs3
  BAD_FLAG="-Wp,-D_GLIBCXX_ASSERTIONS"
  CXXFLAGS="${CXXFLAGS//$BAD_FLAG/}"

#  pushd rpcs3/3rdparty/ffmpeg/
#  ./linux_x86-64.sh
#  popd

  cmake -S rpcs3 -B build \
    -G Ninja \
    -Wno-dev \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_C_COMPILER=gcc \
    -DCMAKE_CXX_COMPILER=g++ \
    -DCMAKE_EXE_LINKER_FLAGS_INIT="-fuse-ld=gold" \
    -DCMAKE_MODULE_LINKER_FLAGS_INIT="-fuse-ld=gold" \
    -DCMAKE_SHARED_LINKER_FLAGS_INIT="-fuse-ld=gold" \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_SKIP_RPATH=ON \
    -DUSE_NATIVE_INSTRUCTIONS=OFF \
    -DBUILD_LLVM=ON \
    -DUSE_SYSTEM_FFMPEG=ON \
    -DUSE_SYSTEM_WOLFSSL=OFF \
    -DUSE_SYSTEM_XXHASH=ON \
    -DUSE_SYSTEM_FAUDIO=ON \
    -DUSE_SYSTEM_LIBUSB=ON \
    -DUSE_SYSTEM_SDL=ON \
    -DUSE_SYSTEM_LIBPNG=ON \
    -DUSE_SYSTEM_ZLIB=ON \
    -DUSE_SYSTEM_CURL=ON \
    -DUSE_SYSTEM_FLATBUFFERS=OFF \
    -DUSE_SYSTEM_PUGIXML=ON \

  ninja -C build -v
}

package() {
  DESTDIR="${pkgdir}" cmake --install build
}

