# Maintainer: 

pkgname=rare
pkgver=1.10.3
pkgrel=2
pkgdesc="A GUI for legendary, an open source replacement for Epic Games Launcher"
arch=('any')
url="https://github.com/Dummerle/Rare"
license=('GPL3')
groups=()
depends=(
  python-pyqt5
  qt5-svg
  python-qtawesome
  python-requests
  python-typing_extensions
  legendary
)
makedepends=(
  git
  python-{build,installer,wheel}
  python-setuptools
)
optdepends=(
  "wine: Run windows games"
  "python-pypresence: Use Discord RPC"
  "python-pywebview: Embeded browser for login"
)
source=("${pkgname%-git}::git+https://github.com/Dummerle/Rare.git#tag=$pkgver")
sha256sums=("SKIP")

build() {
  cd "${pkgname%-git}"
  python -m build -wn
}

package() {
  cd "${pkgname%-git}"
  python -m installer -d "$pkgdir" dist/*.whl
  install -Dm644 "misc/${pkgname%-git}.desktop" "$pkgdir/usr/share/applications/${pkgname%-git}.desktop"
  install -Dm644 "rare/resources/images/Rare.png" "$pkgdir/usr/share/pixmaps/${pkgname%-git}.png"
}
