+    if ( loaddll_optiscaler_hack(name, overrideW, ARRAY_SIZE(overrideW))
+        || loaddll_upscaler_hack(name, overrideW, ARRAY_SIZE(overrideW)) )
+    {
+        FIXME( "HACK: replacing %s with %s\n", debugstr_w(name), debugstr_w(overrideW));
+    }
 
