From 90cb0b5626054e65a0446726748a863ad5fffdba Mon Sep 17 00:00:00 2001
From: Stelios Tsampas <loathingkernel@gmail.com>
Date: Thu, 2 Apr 2026 20:39:56 +0300
Subject: [PATCH 14/16] HACK: kernelbase: add WINE_LOADDLL_REDIRECT to handle
 arbitrary dlls and paths

Update WINE_LOADDLL_REDIRECT format to handle multiple dlls and their paths.
The format tries to immitate WINEDLLOVERRIDES, using a semicolon `;` as the separator
between groups. Each group can set one or more dlls to redirect in a comma `,`
separated list. The target path is specified with an equal sign `=` followed
either by the path to the folder containing the dlls or the replacement
dll itself. There is no path validity checks currently.

The following forms are supported.

`WINE_LOADDLL_REDIRECT=four.dll=c:\\test\\test\\four.dll`

Will load `four.dll` from the specified path.

`WINE_LOADDLL_REDIRECT=one.dll,two.dll,three.dll=c:\\test\\test\\`

Will redirect `one.dll`, `two.dll` and `three.dll` to
`c:\test\test\one.dll`, `c:\test\test\two.dll` and `c:\test\test\three.dll`
respectively

`WINE_LOADDLL_REDIRECT=six.dll=c:\\test\\test\\seven.dll;`

Will redirect `six.dll` to load `seven.dll`
---
 dlls/kernelbase/loader.c | 63 ++++++++++++++++++++++++++++++++++++++--
 1 file changed, 61 insertions(+), 2 deletions(-)

diff --git a/dlls/kernelbase/loader.c b/dlls/kernelbase/loader.c
index 7c7697d3da8..d5d86452dac 100644
--- a/dlls/kernelbase/loader.c
+++ b/dlls/kernelbase/loader.c
@@ -550,8 +550,67 @@ HMODULE WINAPI DECLSPEC_HOTPATCH LoadLibraryExA( LPCSTR name, HANDLE file, DWORD
 
 
 /***********************************************************************
- * LoadLibary replace hack
+ * LoadLibary redirect/replace hack
  */
+BOOL loaddll_redirect(LPCWSTR name, LPWSTR override, DWORD size)
+{
+    WCHAR *entry, *next, *match, *token, *path, *stem;
+    WCHAR envW[MAX_PATH * 8] = {0}, nameW[MAX_PATH] = {0};
+    UINT ret;
+
+    if ( wcsstr( name, L"nvidia/wine/nvngx_dlssg.dll" ) )
+    {
+        TRACE("refusing to redirect %ls\n", name);
+        return FALSE;
+    }
+
+    ret = GetEnvironmentVariableW( L"WINE_LOADDLL_REDIRECT", envW, sizeof(envW));
+    if ( !ret ) return FALSE;
+    if ( ret > ARRAY_SIZE(envW) )
+    {
+        ERR("WINE_LOADDLL_REDIRECT value larger than %zu (%u)\n", ARRAY_SIZE(envW), ret);
+        return FALSE;
+    }
+
+    wcscpy(nameW, name);
+    stem = wcspbrk( nameW, L"\\/" );
+    while (stem)
+    {
+        if ( !wcspbrk( stem + 1, L"\\/" ) )
+            break;
+        stem = wcspbrk( ++stem, L"\\/" );
+    }
+    if ( stem ) stem++;
+    else stem = nameW;
+
+    TRACE("looking for %ls redirect\n", stem);
+
+    entry = envW;
+    while (*entry)
+    {
+        while (*entry == L';') entry++;
+        if (!*entry) break;
+        next = wcschr( entry, L';' );
+        if (next) *next++ = 0;
+        else next = entry + wcslen(entry);
+        if ( (match = wcsstr( entry, stem)) )
+        {
+            path = wcschr( match, L'=' );
+            if (path) *path++ = 0;
+            else return FALSE;
+            token = wcschr( match, L',' );
+            if (token) *token = 0;
+            if ( wcsstr( path, match ) || !wcscmp ( path + wcslen(path) - 4, L".dll" ) )
+                wcscpy( override, path );
+            else
+                swprintf( override, size, L"%s\\%s", path, match );
+            return TRUE;
+        }
+        entry = next;
+    }
+    return FALSE;
+}
+
 BOOL loaddll_replace(LPCWSTR name, LPWSTR override)
 {
     WCHAR envW[64] = {0};
@@ -612,7 +671,7 @@ HMODULE WINAPI DECLSPEC_HOTPATCH LoadLibraryExW( LPCWSTR name, HANDLE file, DWOR
         return 0;
     }
 
-    if ( loaddll_replace(name, overrideW) )
+    if ( loaddll_replace(name, overrideW) || loaddll_redirect(name, overrideW, ARRAY_SIZE(overrideW)) )
         FIXME( "HACK: replaced %s with %s\n", debugstr_w(name), debugstr_w(overrideW));
 
     RtlInitUnicodeString( &str, overrideW[0] ? overrideW : name );
-- 
2.53.0


From 94de32a1521ef5ea3d5fabb6540dba9dc5509846 Mon Sep 17 00:00:00 2001
From: Stelios Tsampas <loathingkernel@gmail.com>
Date: Thu, 9 Apr 2026 15:50:43 +0300
Subject: [PATCH 15/16] HACK: kernelbase: add WINE_OPTISCALER_NAME to load
 optiscaler's dll from an external location

The matching intentionally matches `name.dll` exactly to allow optiscaler
to load the real dll through the fully qualified path.
---
 dlls/kernelbase/loader.c | 17 +++++++++++++----
 1 file changed, 13 insertions(+), 4 deletions(-)

diff --git a/dlls/kernelbase/loader.c b/dlls/kernelbase/loader.c
index d5d86452dac..ebaae91c94d 100644
--- a/dlls/kernelbase/loader.c
+++ b/dlls/kernelbase/loader.c
@@ -568,7 +568,7 @@ BOOL loaddll_redirect(LPCWSTR name, LPWSTR override, DWORD size)
     if ( !ret ) return FALSE;
     if ( ret > ARRAY_SIZE(envW) )
     {
-        ERR("WINE_LOADDLL_REDIRECT value larger than %zu (%u)\n", ARRAY_SIZE(envW), ret);
+        ERR("WINE_LOADDLL_REDIRECT larger than %zu (%u)\n", ARRAY_SIZE(envW), ret);
         return FALSE;
     }
 
@@ -611,16 +611,25 @@ BOOL loaddll_redirect(LPCWSTR name, LPWSTR override, DWORD size)
     return FALSE;
 }
 
-BOOL loaddll_replace(LPCWSTR name, LPWSTR override)
+BOOL loaddll_replace(LPCWSTR name, LPWSTR override, DWORD size)
 {
+    WCHAR dllW[64] = {0};
     WCHAR envW[64] = {0};
     UINT ret;
 
+    ret = GetEnvironmentVariableW( L"WINE_OPTISCALER_NAME", dllW, sizeof(dllW));
+    if ( !ret || ret > ARRAY_SIZE(dllW) ) return FALSE;
+    if ( !wcscmp( name, dllW ) )
+    {
+        swprintf( override, size, L"c:\\windows\\system32\\umu\\%s", dllW );
+        return TRUE;
+    }
+
     ret = GetEnvironmentVariableW( L"WINE_LOADDLL_REPLACE", envW, sizeof(envW));
     if ( !ret ) return FALSE;
     if ( ret > ARRAY_SIZE(envW) )
     {
-        ERR("WINE_LOADDLL_REPLACE value larger than %zu (%u)\n", ARRAY_SIZE(envW), ret);
+        ERR("WINE_LOADDLL_REPLACE larger than %zu (%u)\n", ARRAY_SIZE(envW), ret);
         return FALSE;
     }
 
@@ -671,7 +680,7 @@ HMODULE WINAPI DECLSPEC_HOTPATCH LoadLibraryExW( LPCWSTR name, HANDLE file, DWOR
         return 0;
     }
 
-    if ( loaddll_replace(name, overrideW) || loaddll_redirect(name, overrideW, ARRAY_SIZE(overrideW)) )
+    if ( loaddll_replace(name, overrideW, ARRAY_SIZE(overrideW)) || loaddll_redirect(name, overrideW, ARRAY_SIZE(overrideW)) )
         FIXME( "HACK: replaced %s with %s\n", debugstr_w(name), debugstr_w(overrideW));
 
     RtlInitUnicodeString( &str, overrideW[0] ? overrideW : name );
