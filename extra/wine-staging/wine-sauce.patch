From 179e5e1ee5cb5bb819e3b490b1a02716aa3e52df Mon Sep 17 00:00:00 2001
From: Arkadiusz Hiler <ahiler@codeweavers.com>
Date: Fri, 17 Oct 2025 11:23:58 +0300
Subject: [PATCH 07/12] fixup! win32u: Bump GPU internal driver versions to a
 future version.

Dune: Awakening still complains about driver version with Nvidia GPUs.
Looks like they don't compare the full version in a semantic way - only
a part of it seems to be used.

This brings the old behavior we had with Proton 9 to use all 9s for the
actively used digits.

CW-Bug-Id: #25893
---
 dlls/win32u/sysparams.c | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/dlls/win32u/sysparams.c b/dlls/win32u/sysparams.c
index 1d4ef464e82..4ccb844dde3 100644
--- a/dlls/win32u/sysparams.c
+++ b/dlls/win32u/sysparams.c
@@ -1113,10 +1113,10 @@ static const char* driver_vendor_to_version( UINT16 vendor )
     /* The last seven digits are the driver number. */
     switch (vendor)
     {
-    case 0x8086: /* Intel */    return "35.0.101.6314";
-    case 0x1002: /* AMD */      return "35.0.21025.1024";
-    case 0x10de: /* Nvidia */   return "35.0.19.9999";
-    default:                    return "35.0.10.1000";
+    case 0x8086: /* Intel */    return "35.0.999.9999";
+    case 0x1002: /* AMD */      return "35.0.99999.9999";
+    case 0x10de: /* Nvidia */   return "35.0.99.9999";
+    default:                    return "35.0.99.9999";
     }
 }
 
-- 
2.53.0


From 0aebe8ae642e8f3f07617c235100f45ca8fd9021 Mon Sep 17 00:00:00 2001
From: William Horvath <william@horvath.blog>
Date: Fri, 22 Nov 2024 10:31:07 -0800
Subject: [PATCH 08/12] configure: Enforce 4-byte stack alignment on clang for
 PE builds.

Same as -mpreferred-stack-boundary=2 for gcc.
Clang interprets this as "n" bytes, while gcc uses "2^n" bytes.
https://linux.kernel.narkive.com/y7hAplfS/patch-x86-build-specify-stack-alignment-for-clang
---
 configure.ac | 1 +
 1 file changed, 1 insertion(+)

diff --git a/configure.ac b/configure.ac
index 89243b45be0..e48737cbb94 100644
--- a/configure.ac
+++ b/configure.ac
@@ -625,6 +625,7 @@ This is an error since --enable-archs=$wine_arch was requested.])])
 
     case $wine_arch in
       i386) WINE_TRY_PE_CFLAGS([-fno-omit-frame-pointer])
+            WINE_TRY_PE_CFLAGS([-mstack-alignment=4])
             WINE_TRY_PE_CFLAGS([-mpreferred-stack-boundary=2])
             WINE_TRY_PE_CFLAGS([-mlong-double-64])
             WINE_TRY_PE_CFLAGS([-Wl,--disable-stdcall-fixup],
-- 
2.53.0


