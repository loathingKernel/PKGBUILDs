name: linux-zen-elitebook

on:
  workflow_dispatch:
  push:
    branches:
     - master
    paths:
     - local/linux-zen-elitebook/.SRCINFO

jobs:
  personal:
    uses: ./.github/workflows/_job_pkgbuild.yml
    with:
      pkgdir: local/linux-zen-elitebook
      pacman_conf: .github/conf/personal_pacman.conf
      makepkg_conf: .github/conf/personal_makepkg.conf
      makepkg_args: -p PKGBUILD --skippgpcheck
      release_tag: loathk-personal
